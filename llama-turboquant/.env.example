# llama-turboquant cli.sh ayarlari
# Kullanim: bu dosyayi .env olarak kopyala ve degerleri duzenle.
#   cp .env.example .env
# Ozel yol icin: ENV_FILE=/path/to/.env ./cli.sh start

# --- Ag ---
HOST=0.0.0.0
PORT=8001

# --- Dizinler / dosyalar (genelde dokunmaya gerek yok) ---
# LLAMA_DIR=
# MODEL_DIR=
# LOG_FILE=
# PID_FILE=

# --- Model ---
MODEL_URL=https://huggingface.co/unsloth/Qwen3.6-35B-A3B-MTP-GGUF/resolve/main/Qwen3.6-35B-A3B-UD-Q5_K_XL.gguf
# MODEL_FILE=

# --- Multimodal (vision) ---
ENABLE_MMPROJ=1
MMPROJ_URL=https://huggingface.co/unsloth/Qwen3.6-35B-A3B-MTP-GGUF/resolve/main/mmproj-F16.gguf
# MMPROJ_FILE=

# --- L40S 48GB performans ---
CTX_SIZE=262144
PARALLEL_SLOTS=1
GPU_LAYERS=99
BATCH_SIZE=1024
UBATCH_SIZE=512
THREADS=0

# --- MTP / speculative decoding ---
SPEC_DRAFT_N_MAX=6

# --- TurboQuant KV cache ---
CACHE_TYPE_K=turbo4
CACHE_TYPE_V=turbo4

# --- Qwen reasoning butcesi (0=kapali, 4096=dengeli, 8192=uzun) ---
REASONING_BUDGET=4096

# --- Web UI / slots / API key ---
ENABLE_WEBUI=1
ENABLE_SLOTS=1
API_KEY=
