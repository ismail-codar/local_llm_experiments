# LFM2.5-8B-A1B (APEX I-Balanced GGUF) - cli.sh ayarlari
# Model karti: https://huggingface.co/LiquidAI/LFM2.5-8B-A1B
# GGUF repo:   https://huggingface.co/mudler/LFM2.5-8B-A1B-APEX-GGUF
#
# Kullanim:
#   ./cli.sh --env ./lfm8b.env start
#   ./cli.sh --env ./lfm8b.env stop
#   ./cli.sh --env ./lfm8b.env log
#
# Mimari: hybrid MoE (short-conv + GQA), 24 katman (18 conv + 6 attn)
# Toplam 8.3B parametre, token basina ~1.5B aktif (32 routed expert, 4 aktif)

# --- Ag ---
HOST=0.0.0.0
# Qwen varsayilani 8001 ile cakismamak icin farkli port
PORT=8003

# --- Model (APEX I-Balanced, ~6.3 GB, imatrix kalibreli) ---
MODEL_URL=https://huggingface.co/mudler/LFM2.5-8B-A1B-APEX-GGUF/resolve/main/LFM2.5-8B-A1B-APEX-I-Balanced.gguf
MODEL_FILE=$MODEL_DIR/LFM2.5-8B-A1B-APEX-I-Balanced.gguf

# --- Multimodal: LFM2.5-8B-A1B salt-metin, vision yok ---
ENABLE_MMPROJ=0

# --- Context: model 128K destekliyor ---
CTX_SIZE=131072
PARALLEL_SLOTS=1
GPU_LAYERS=99
BATCH_SIZE=1024
UBATCH_SIZE=512
THREADS=0

# --- MTP: LFM2.5'te draft/MTP katmani yok -> kapali ---
ENABLE_MTP=0

# --- TurboQuant KV cache (KV quantizasyonu, mimari bagimsiz) ---
CACHE_TYPE_K=turbo4
CACHE_TYPE_V=turbo4

# --- Reasoning: model reasoning-tuned. Bos = model/llama.cpp varsayilani ---
REASONING_BUDGET=

# --- Sampling (LiquidAI model kartinda onerilen degerler) ---
TEMP=0.2
TOP_K=80
REPEAT_PENALTY=1.05
# top_p / min_p model kartinda belirtilmemis -> gecilmiyor (llama.cpp varsayilani)
TOP_P=
MIN_P=

# --- Web UI / slots / API key ---
ENABLE_WEBUI=1
ENABLE_SLOTS=1
API_KEY=
