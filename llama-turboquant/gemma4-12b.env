# Gemma-4-12B-it (Unsloth Dynamic UD-Q5_K_XL GGUF) - cli.sh ayarlari
# Model karti: https://huggingface.co/google/gemma-4-12b-it
# GGUF repo:   https://huggingface.co/unsloth/gemma-4-12b-it-GGUF
#
# Kullanim:
#   ./cli.sh --env ./gemma4-12b.env start
#   ./cli.sh --env ./gemma4-12b.env stop
#   ./cli.sh --env ./gemma4-12b.env log
#
# Mimari: dense, 12B parametre, text + vision (multimodal).
# Quant: UD-Q5_K_XL (Unsloth dynamic 5-bit) -> kalite/VRAM dengesi iyi, ~8.6 GB.


INSTALL_REPO_URL=https://github.com/Anbeeld/beellama.cpp
INSTALL_BRANCH=main

# llama.cpp/beellama kurulum + calistirma dizini.
# Duz atama: cli.sh L30 seed'inin uzerine yazar -> beellama.cpp dizinine kurar/calistirir.
LLAMA_DIR=$ROOT_DIR/beellama.cpp

# --- Ag ---
HOST=0.0.0.0
# Qwen 8001, LFM 8003, MiniCPM 8004 ile cakismamak icin farkli port
PORT=8005

# --- Model (UD-Q5_K_XL, ~8.6 GB) ---
MODEL_URL=https://huggingface.co/unsloth/gemma-4-12b-it-GGUF/resolve/main/gemma-4-12b-it-UD-Q5_K_XL.gguf
MODEL_FILE=$MODEL_DIR/gemma-4-12b-it-UD-Q5_K_XL.gguf

# --- Multimodal: Gemma-4-12B vision destekliyor -> mmproj indir ve ekle ---
ENABLE_MMPROJ=0
MMPROJ_URL=https://huggingface.co/unsloth/gemma-4-12b-it-GGUF/resolve/main/mmproj-F16.gguf
MMPROJ_FILE=$MODEL_DIR/gemma-4-12b-it-mmproj-F16.gguf

# --- Context: model 128K destekliyor ---
CTX_SIZE=131072
PARALLEL_SLOTS=1
GPU_LAYERS=99
BATCH_SIZE=1024
UBATCH_SIZE=512
THREADS=0

# --- MTP: Gemma'da draft/MTP katmani yok -> kapali ---
ENABLE_MTP=0

# --- TurboQuant KV cache ---
CACHE_TYPE_K=turbo4
CACHE_TYPE_V=turbo4

# --- Reasoning: Gemma reasoning/thinking modeli degil, <think> uretmez.
# Bos birak -> --reasoning hic gecilmez (varsayilan). ---
REASONING=
REASONING_BUDGET=
REASONING_FORMAT=

# --- Ozel chat template: gerek yok, modelin gomulu Gemma template'i kullanilir ---
CHAT_TEMPLATE_FILE=

# --- Sampling (Gemma onerilen degerleri) ---
TEMP=1.0
TOP_K=64
TOP_P=0.95
MIN_P=0.0
REPEAT_PENALTY=

# --- Web UI / slots / API key ---
ENABLE_WEBUI=1
ENABLE_SLOTS=1
API_KEY=
