# Gemma-4-26B-A4B-it (MoE, ~4B aktif) + DFlash speculative decoding - cli.sh ayarlari
# Kaynak quickstart: https://github.com/Anbeeld/beellama.cpp/blob/main/docs/quickstart-gemma-4-31b-dflash.md
# Target GGUF: https://huggingface.co/unsloth/gemma-4-26B-A4B-it-GGUF
# Draft GGUF:  https://huggingface.co/Anbeeld/gemma-4-26B-A4B-it-DFlash-GGUF
#
# Kullanim:
#   ./cli.sh --env ./gemma4-dflash.env install
#   ./cli.sh --env ./gemma4-dflash.env start
#   ./cli.sh --env ./gemma4-dflash.env stop
#   ./cli.sh --env ./gemma4-dflash.env log
#
# Not: 26B-A4B MoE mimari (26B toplam, ~4B aktif parametre) -> 31B dense'e gore
# cok daha hizli/dusuk VRAM. DFlash draft modeli ayni 26B-A4B icin uretilmis.

INSTALL_REPO_URL=https://github.com/Anbeeld/beellama.cpp
INSTALL_BRANCH=main

# llama.cpp/beellama kurulum + calistirma dizini.
# Duz atama: cli.sh L30 seed'inin uzerine yazar -> beellama.cpp dizinine kurar/calistirir.
LLAMA_DIR=$ROOT_DIR/beellama.cpp

# --- Ag ---
HOST=0.0.0.0
# Qwen 8001, LFM 8003, MiniCPM 8004, Gemma12B 8005 ile cakismamak icin
PORT=8006

# --- Target model (Balanced: UD-Q4_K_S ~16.5 GB; UD-Q4_K_XL / UD-Q5_K_XL alternatif) ---
MODEL_URL=https://huggingface.co/unsloth/gemma-4-26B-A4B-it-GGUF/resolve/main/gemma-4-26B-A4B-it-UD-Q4_K_S.gguf
MODEL_FILE=$MODEL_DIR/gemma-4-26B-A4B-it-UD-Q4_K_S.gguf

# --- DFlash draft model (IQ4_XS ~246 MB; Q4_K_M / Q5_K_M alternatifleri de var) ---
ENABLE_DFLASH=1
DRAFT_MODEL_URL=https://huggingface.co/Anbeeld/gemma-4-26B-A4B-it-DFlash-GGUF/resolve/main/gemma4-26b-a4b-it-dflash-IQ4_XS.gguf
DRAFT_MODEL_FILE=$MODEL_DIR/gemma4-26b-a4b-it-dflash-IQ4_XS.gguf
# Draft katmanlarinin tamami GPU'ya (quickstart: --spec-draft-ngl all)
SPEC_DRAFT_NGL=99
# Drafter'in gordugu target hidden-state token sayisi (quickstart: 1024)
SPEC_DFLASH_CROSS_CTX=1024

# --- Multimodal: opsiyonel (gerekmiyorsa kapali birak) ---
ENABLE_MMPROJ=0
MMPROJ_URL=https://huggingface.co/unsloth/gemma-4-26B-A4B-it-GGUF/resolve/main/mmproj-BF16.gguf
MMPROJ_FILE=$MODEL_DIR/gemma-4-26B-A4B-it-mmproj-BF16.gguf

# --- Context (quickstart: 102400) ---
CTX_SIZE=102400
PARALLEL_SLOTS=1
GPU_LAYERS=99
BATCH_SIZE=2048
UBATCH_SIZE=512
THREADS=0

# --- MTP kapali: spec-decoding DFlash uzerinden yapiliyor ---
ENABLE_MTP=0

# --- KV cache (quickstart balanced: K=q5_0, V=q4_1) ---
CACHE_TYPE_K=q5_0
CACHE_TYPE_V=q4_1

# --- Reasoning: Gemma-4 reasoning destekliyor (quickstart: --reasoning on) ---
REASONING=on
REASONING_BUDGET=
REASONING_FORMAT=

# --- Ozel chat template: gerek yok, gomulu Gemma template'i kullanilir ---
CHAT_TEMPLATE_FILE=

# --- Sampling (Gemma onerilen degerleri) ---
TEMP=1.0
TOP_K=64
TOP_P=0.95
MIN_P=0.0
REPEAT_PENALTY=

# --- Web UI / slots / API key ---
ENABLE_WEBUI=1
ENABLE_SLOTS=1
API_KEY=
