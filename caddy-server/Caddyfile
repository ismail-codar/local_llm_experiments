{
	admin off
	auto_https off
}

:7999 {
	log {
		output file access.log
		format json
	}

	# WebUI'ler relative asset yolu (./bundle.js) kullandigindan, bare
	# subpath ('/llama') trailing-slash'a yonlendirilmeli; aksi halde
	# './bundle.js' koke ('/bundle.js') cozulur ve catch-all'a duser.
	redir /llama /llama/ 308

	@llama path /llama /llama/*
	handle @llama {
		uri strip_prefix /llama
		reverse_proxy localhost:8001
	}

	# EmbeddingGemma-300M (embedding-only llama-server, bkz.
	# llama-turboquant/embeddinggemma-300m.env -> PORT=8009).
	# Orn: POST /embed/v1/embeddings -> upstream /v1/embeddings
	@embed path /embed /embed/*
	handle @embed {
		uri strip_prefix /embed
		reverse_proxy localhost:8009
	}

	redir /searxng /searxng/ 308
	@searxng path /searxng /searxng/*
	handle @searxng {
		uri strip_prefix /searxng
		reverse_proxy localhost:3333
	}

	redir /localai /localai/ 308
	@localai path /localai /localai/*
	handle @localai {
		# Prefix'i STRIPLE ETME: LocalAI subpath'i X-Forwarded-Prefix ile
		# kendisi hallediyor (PR #4497). Yolu olduğu gibi geçir, sadece
		# header'ı ekle; LocalAI asset/redirect URL'lerini /localai ile üretir.
		reverse_proxy localhost:8000 {
			header_up X-Forwarded-Prefix /localai
		}
	}

	handle {
		respond "caddy ok" 200
	}
}

# TripoSplat (gradio) — kendi frontend'i mutlak yollar kullandığından
# (window.location.origin, /api/*, /viewer) subpath altında çalışmaz;
# bu yüzden kök yolda kendi portunda yayınlanır.
# Uygulama localhost:8010'a bind eder (bkz. triposplat/cli.sh).
:7998 {
	reverse_proxy localhost:8010
}
